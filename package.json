{
  "name": "orx",
  "version": "0.1.0",
  "description": "OpenRouter-native terminal coding agent with local coding tools, MCP/plugin surfaces, and release checks.",
  "type": "module",
  "bin": {
    "orx": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.spec.d.ts",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.js.map",
    "README.md",
    "RELEASE_NOTES.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "verify:global-install": "node scripts/verify-global-install.mjs",
    "verify:tty-first-screen": "node scripts/assert-tty-first-screen.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepare": "npm run build"
  },
  "dependencies": {
    "eventsource-parser": "^3.1.0",
    "smol-toml": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "openrouter",
    "cli",
    "terminal",
    "coding-agent",
    "agent",
    "mcp",
    "tui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matt-ceran/ORX.git"
  },
  "bugs": {
    "url": "https://github.com/matt-ceran/ORX/issues"
  },
  "homepage": "https://github.com/matt-ceran/ORX#readme"
}
